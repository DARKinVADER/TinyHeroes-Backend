# .env.example — copy to .env and fill in values
POSTGRES_DB=tinyheroes
POSTGRES_USER=tinyheroes
POSTGRES_PASSWORD=changeme

JWT_SECRET=replace-with-32-char-minimum-secret-key
JWT_ISSUER=tinyheroes-api
JWT_AUDIENCE=tinyheroes-frontend
JWT_EXPIRY_MINUTES=60

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of the frontend — used to build the OAuth redirect after social login
# Change this to your real domain when deploying (e.g. https://mytinyheroes.net)
FRONTEND_URL=http://localhost:4200
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Cloudflare Turnstile — bot protection on login and registration forms
# Get your site key + secret key from https://dash.cloudflare.com → Turnstile
# Dev test secret (always passes): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# Storage — local disk by default; swap connection string for cloud:
# AWS S3:    aws.s3://keyId=...;key=...;bucket=tinyheroes;region=eu-central-1
# Azure:     azure.blob://account=...;key=...
# GCS:       google.storage://bucket=tinyheroes;cred=base64
STORAGE_CONNECTION_STRING=disk://path=/app/uploads

# AI Image Generation — Hugging Face Serverless Inference API (free tier)
# Model: black-forest-labs/FLUX.1-schnell (fast) or bytedance/sdxl-lightning-4step
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-schnell

# pgAdmin — MUST be changed before exposing pgAdmin to any network
PGADMIN_EMAIL=admin@tinyheroes.com
PGADMIN_PASSWORD=changeme

# Logging — Seq (local dev log viewer; see docs/deployment.md for the local URL)
SEQ_URL=http://seq:5341

# Logging — Azure Logs Ingestion API (integration + production)
# Both environments share the same DCE endpoint and Entra app registration.
# The streamName in appsettings.Integration/Production.json separates the Log Analytics tables.
# Add the five credential values as Application Settings in each Azure App Service:
#   Serilog__WriteTo__1__Args__credentials__endpoint      = <DCE Logs Ingestion URL>
#   Serilog__WriteTo__1__Args__credentials__immutableId   = <DCR Immutable ID>
#   Serilog__WriteTo__1__Args__credentials__tenantId      = <Entra Tenant ID>
#   Serilog__WriteTo__1__Args__credentials__clientId      = <App Registration Client ID>
#   Serilog__WriteTo__1__Args__credentials__clientSecret  = <App Registration Client Secret>
AZURE_LOG_ANALYTICS_ENDPOINT=
AZURE_LOG_ANALYTICS_IMMUTABLE_ID=
AZURE_LOG_ANALYTICS_TENANT_ID=
AZURE_LOG_ANALYTICS_CLIENT_ID=
AZURE_LOG_ANALYTICS_CLIENT_SECRET=

# Metrics + Traces — Azure Application Insights
# Enable Application Insights on each App Service in the Azure portal (Monitoring → Application Insights → Enable).
# Azure injects APPLICATIONINSIGHTS_CONNECTION_STRING automatically — no manual App Setting needed.
# Resources: tinyheroes-api-integration (integration), tinyheroes-api (production).
# Both use workspace-based mode pointing at the same Log Analytics workspace as Serilog.
# For local testing only, set manually: InstrumentationKey=...;IngestionEndpoint=...
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Email (feedback form) — Resend SMTP relay (resend.com, free tier: 3000/month)
# See docs/superpowers/specs/2026-06-06-feedback-reporting-design.md for full setup steps.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=                          # Resend API key (re_xxxxxxxxxxxxxxxxxxxx)
SMTP_FROM=noreply@mytinyheroes.net      # must match your verified Resend domain
SMTP_ADMIN_ADDRESS=feedback@mytinyheroes.net  # receives all feedback submissions
